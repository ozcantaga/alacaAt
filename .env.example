# ─── Hotel API Provider ───────────────────────────────────────────────────────
# Aktif provider: 'mock' | 'elektraweb' | 'hotelrunner'
HOTEL_PROVIDER=mock

# ─── ElektraWeb ───────────────────────────────────────────────────────────────
# API anahtarı boş bırakılırsa → SIM MODU otomatik aktif olur (test için ideal)
# Gerçek entegrasyon için ElektraWeb'den API anahtarı alın.
ELEKTRAWEB_API_KEY=
ELEKTRAWEB_BASE_URL=https://api.elektraweb.com
ELEKTRAWEB_HOTEL_ID=
ELEKTRAWEB_PAYMENT_URL=

# ─── HotelRunner ─────────────────────────────────────────────────────────────
HOTELRUNNER_API_KEY=
HOTELRUNNER_TOKEN=
HOTELRUNNER_HOTEL_ID=
HOTELRUNNER_APP_KEY=
